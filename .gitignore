# 3. Environment Variables & Secrets (CRITICAL)
# -------------------------------------------------------------------------
# Ignore all actual secret files containing credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# BUT, allow pushing template env configurations so others know what keys to set up:
!.env.example

# SSH & security keys
*.pem
*.key
*.pub
*.cert
*.pfx

